# Target repository on your private registry (host:port/image path, NO tag).
# Tags pushed by the script are appended by Docker (NZBGet version, combined tag, "testing").
LOCAL_REPO=192.168.1.1:5000/nzbgetvpn

# Optional. Passed to: docker buildx build --platform ...
# Examples: linux/amd64   or   linux/amd64,linux/arm64
# LOCAL_PLATFORM=linux/amd64,linux/arm64
